---
import { getCollection } from "astro:content";
import PostList from "../components/PostList.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { projects } from "../data/projects";
import { site, sortPostsByDate } from "../lib/site";

const posts = sortPostsByDate((await getCollection("posts")).filter((post) => post.data.indexable)).slice(0, 6);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: site.name,
  url: site.url,
  description: "zozindev의 개인 취미 블로그, 포트폴리오, 웹 도구를 모아둔 루트 페이지다.",
  publisher: {
    "@type": "Person",
    name: site.name,
    url: site.url,
    sameAs: [site.githubUrl, site.instagramUrl],
  },
};
---

<BaseLayout
  title="zozindev | Blog, Portfolio & Web Tools"
  description="zozindev의 개인 취미 블로그, 포트폴리오, 웹 도구를 모아둔 루트 페이지다."
  canonicalPath="/"
  ogTitle="zozindev | Blog, Portfolio & Web Tools"
  ogDescription="브라우저 전용 웹 도구, 사용 가이드, 개인정보 처리 기준, 제작 기록을 모아둔 개인 콘텐츠 허브다."
  structuredData={structuredData}
  includeAdsenseScript={false}
>
  <section class="hero" aria-labelledby="site-title">
    <h1 id="site-title">ZOZINDEV</h1>
    <p class="intro">직접 만든 브라우저 도구와 실제로 써보며 정리한 기준</p>
  </section>

  <section class="nav-panel" aria-label="Site sections">
    <a class="button-link" href="/blog/">Blog</a>
    <a class="button-link" href="/projects/">Projects</a>
    <a class="button-link" href="/about/">About</a>
    <a class="button-link" href="/contact/">Contact</a>
    <a class="button-link" href="/privacy/">Privacy</a>
  </section>

  <section class="posts" aria-labelledby="site-purpose-title">
    <h2 id="site-purpose-title">여기서 다루는 것</h2>
    <p>이미지 한 장 가리려고 파일을 서버에 올리기 싫었고, 썸네일 하나 만들려고 큰 편집기를 켜기 싫었다. 여행 정산을 하면서 영수증마다 참여자가 다른 경우도 자주 헷갈렸다. 이 사이트에 연결된 도구는 그런 작은 불편에서 시작했다.</p>
    <p>루트 사이트에는 앱 링크만 두지 않는다. 실제 화면, 입력 예시, 계산 결과, 브라우저에서 확인한 저장 방식과 한계를 같이 남긴다. 도구가 해결하지 못하는 부분도 숨기지 않는다.</p>
    <p>처음 보는 사람이라면 아래 다섯 가이드 중 필요한 것부터 보면 된다. 각 글은 지금 운영 중인 도구와 실제 결과물을 기준으로 작성했다.</p>
  </section>

  <section class="posts" aria-labelledby="guide-start-title">
    <h2 id="guide-start-title">Guide starting points</h2>
    <p>처음 들어왔다면 아래 글부터 보면 된다. 각 글은 도구 사용법만 적는 게 아니라, 왜 그 기준이 필요한지와 어떤 한계가 있는지까지 같이 정리했다.</p>
    <ul>
      <li><a href="/blog/2026-07-01-dutchpay-settlement-checklist/">더치페이 정산 실수 줄이는 체크리스트</a></li>
      <li><a href="/blog/2026-07-01-screenshot-masking-routine/">캡처 이미지 공유 전 5분 마스킹 루틴</a></li>
      <li><a href="/blog/2026-07-01-blog-thumbnail-text-image-workflow/">텍스트 이미지를 블로그 썸네일로 쓰는 방법</a></li>
      <li><a href="/blog/2026-07-01-lunch-menu-shortlist-rules/">점심 메뉴를 빨리 정하는 기준</a></li>
      <li><a href="/blog/2026-07-01-browser-only-tool-checkpoints/">브라우저 전용 도구를 고를 때 확인할 점</a></li>
    </ul>
  </section>

  <section class="posts" aria-labelledby="posts-title">
    <h2 id="posts-title">Recent Posts</h2>
    <PostList posts={posts} />
    <a class="text-link" href="/blog/">모든 글 보기</a>
  </section>

  <section class="projects" aria-labelledby="projects-title">
    <h2 id="projects-title">Projects</h2>
    <p>각 프로젝트는 실행 링크보다 설명 페이지를 먼저 둔다. 어떤 문제를 줄이는지, 입력값을 어디에 저장하는지, 실제로 어떤 상황에서 쓰면 좋은지를 확인한 뒤 앱으로 이동할 수 있게 했다.</p>
    {
      projects.map((project) => (
        <article class="project-item">
          <a class="card-link" href={project.detailUrl} aria-label={`${project.title} 자세히 보기`} />
          <div>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </div>
          <div class="project-actions">
            <a class="button-link" href={project.detailUrl}>자세히</a>
            <a class="button-link" href={project.url} target="_blank" rel="noopener noreferrer">Open</a>
          </div>
        </article>
      ))
    }
    <a class="text-link" href="/projects/">모든 프로젝트 보기</a>
  </section>

  <footer class="site-footer">
    <a href="/privacy/">Privacy Policy</a>
    <a href="/about/">About</a>
    <a href="/contact/">Contact</a>
    <a href="/blog/">Blog</a>
    <a href="/projects/">Projects</a>
    <a href={site.githubUrl} target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href={site.instagramUrl} target="_blank" rel="noopener noreferrer">Instagram</a>
  </footer>
</BaseLayout>
