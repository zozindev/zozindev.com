---
import { getCollection } from "astro:content";
import PostList from "../../components/PostList.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { sortPostsByDate } from "../../lib/site";

const posts = sortPostsByDate((await getCollection("posts")).filter((post) => post.data.indexable));
const guidePosts = posts.filter((post) => post.data.category === "guide");
const caseStudies = posts.filter((post) => post.data.category === "case-study");
---

<BaseLayout
  title="Blog - zozindev"
  description="zozindev의 개발 기록, 취미 프로젝트 제작 과정, 정적 웹사이트 운영 노트를 모아둔 블로그다."
  canonicalPath="/blog/"
  ogTitle="Blog - zozindev"
  ogDescription="zozindev의 개발 기록과 취미 프로젝트 제작 과정을 적어둔다."
  includeAdsenseScript={false}
>
  <section class="hero" aria-labelledby="blog-title">
    <p class="eyebrow">Blog</p>
    <h1 id="blog-title">zozindev Blog</h1>
    <p class="intro">개인 웹 도구를 만들고 쓰면서 확인한 기준, 사용 가이드, 제작 기록을 적어둔다.</p>
  </section>

  <section class="posts" aria-labelledby="blog-guide-title">
    <h2 id="blog-guide-title">사용 가이드</h2>
    <p>정산, 캡처 이미지, 텍스트 썸네일, 메뉴 결정, 브라우저 처리 여부를 실제 예시와 함께 정리했다.</p>
    <PostList posts={guidePosts} />
  </section>

  <section class="posts" aria-labelledby="blog-project-title">
    <h2 id="blog-project-title">제작 사례</h2>
    <p>실제로 만든 기능, 배포 구조, 실패한 부분과 다음 수정 기준을 남긴다.</p>
    <PostList posts={caseStudies} />
  </section>

  <section class="posts" aria-labelledby="posts-title">
    <h2 id="posts-title">All Posts</h2>
    <PostList posts={posts} />
  </section>

  <footer class="site-footer">
    <a href="/">Home</a>
    <a href="/projects/">Projects</a>
    <a href="/about/">About</a>
    <a href="/contact/">Contact</a>
    <a href="/privacy/">Privacy Policy</a>
  </footer>
</BaseLayout>
